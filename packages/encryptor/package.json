{
  "name": "@alephium/encryptor",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --fix --ext .ts",
    "test": "jest --useStderr --silent=false --verbose=true --config jestconfig.json --passWithNoTests",
    "test:watch": "pnpm run test -- --watch",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" --log-level silent",
    "clean": "rm -rf dist",
    "clean:node-modules": "rm -rf node_modules",
    "typecheck": "tsup"
  },
  "dependencies": {
    "@metamask/browser-passworder": "^4.3.0",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@alephium/eslint-config": "workspace:*",
    "@alephium/typescript-config": "workspace:*",
    "@types/jest": "^29.4.0",
    "@types/node": "^16.10.1",
    "@types/rewire": "^2.5.28",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^29.4.3",
    "rewire": "^6.0.0",
    "ts-jest": "^29.0.5",
    "tslib": "^2.3.1",
    "typescript": "^5.2.2"
  }
}
